CONTROL_PLANE_PORT=auto
APP_BASE_URL=http://localhost:3000
APP_ENV=development

# Autonomy for NEW work sessions: manual | checkpoint | supervised | full_auto
# NOTE!: full_auto runs the entire plan→execute→verify loop with no human gate.
DEFAULT_AUTONOMY_LEVEL=checkpoint

# Require explicit plan approval before any code is written.
AUTO_APPROVE_PLANS=false

# Persistent embedded storage. Relative paths resolve from the project root.
DB_FILE=.data/closed-dev-loop.json
WORKSPACE_ROOT=.workspace
ARTIFACTS_DIR=.data/artifacts

# Runtime provider
AGENT_PROVIDER=codex-cli
PLANNER_PROVIDER=codex-cli
DEFAULT_PROJECT_STACK=
PLANNER_TIMEOUT_MS=2400000
CONTROLLER_MAX_STEPS_PER_TICK=8

# For exporting generated apps to GitHub. Device-flow client ID (public identifier, not a secret).
GITHUB_CLIENT_ID=

# Local Codex CLI backend provider. Leave *_BIN blank to auto-discover from PATH.
CODEX_CLI_BIN=
CODEX_EXTRA_ARGS=
CODEX_SANDBOX_MODE=workspace-write # danger-full-access
CODEX_APPROVAL_POLICY=never # Codex's own approval prompt. 
CODEX_TIMEOUT_MS=6000000
CODEX_MODEL=
CODEX_REASONING_EFFORT=
CODEX_TRANSPORT_MODE=auto

# Local Claude Code backend provider
CLAUDE_TRANSPORT_MODE=auto
CLAUDE_PERSISTENT_SESSIONS=true
CLAUDE_TIMEOUT_MS=6000000
CLAUDE_ULTRACODE=false
CLAUDE_ULTRACODE_TOOLS=Read;Edit;Write;Glob;Grep;Task;Workflow
CLAUDE_ULTRACODE_MAX_TURNS=200
CLAUDE_ULTRACODE_MAX_BUDGET_USD=5

# Local Ollama backend provider.
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=
OLLAMA_TIMEOUT_MS=600000
OLLAMA_MAX_ITERATIONS=24
OLLAMA_TOOLS_MODE=auto
OLLAMA_TEMPERATURE=0.2
OLLAMA_NUM_CTX=
OLLAMA_KEEP_ALIVE=5m

# Optional R interpreter for the r-script / r-shiny stacks. Leave blank to auto-discover Rscript from
RSCRIPT_BIN=
R_BIN=

# Verification commands (semicolon-separated). 
VERIFY_COMMANDS=npm run typecheck;npm run lint
SHELL_TIMEOUT_MS=1200000

# Stop completed generated-app previews after idle time (ms).
PREVIEW_IDLE_TIMEOUT_MS=300000
PREVIEW_HOST=127.0.0.1

# Verification-only trust flag; never selects the app root as an implementation workspace.
ALLOW_APP_ROOT_VERIFICATION=true

#Optional Telegram remote control (off by default) ---

TELEGRAM_CONTROL_ENABLED=false
TELEGRAM_BOT_TOKEN= #1234567890:AA_token_from_BotFather
TELEGRAM_CONTROL_APP_URL=http://127.0.0.1:3000
TELEGRAM_CONTROL_WORKER_TOKEN= #random_64_hex_char_secret`
TELEGRAM_CONTROL_ALLOWED_USER_IDS=
TELEGRAM_CONTROL_ALLOWED_CHAT_IDS=
TELEGRAM_CONTROL_GROUPS_ENABLED=false

# Optional: forward domain events to an external sink. 
EVENT_WEBHOOK_URL=


##### Otional ML ####

ML_PIPELINE_ENABLED=true # Enable for ML pipeline
ML_ALLOW_GPU=true
ML_JOB_TIMEOUT_MS=6000000
ML_DISK_BUDGET_MB=2000
ML_DATA_UPLOAD_MAX_MB = 2000
ML_DATA_UPLOAD_MAX_FILES = 5000
ML_DATA_UPLOAD_MAX_TOTAL_MB = 10240
